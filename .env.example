# ── Backend ──────────────────────────────────────
FIRECRAWL_API_KEY=
LINKEDIN_SESSION_FILE=data/linkedin_auth.json

# ── Search API (Brave Search) ───────────────────
BRAVE_SEARCH_API_KEY=

# ── LLM (OpenRouter) ────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Dashboard ───────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_API_TOKEN=

# ── Sistema ─────────────────────────────────────
ORCHESTRATOR=Manu
SYSTEM_NAME=GE Recruiting Desk
LOG_LEVEL=info

# ── Playwright (opcional) ───────────────────────
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=false

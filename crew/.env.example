# EcoSign — Hermes Agent Config
# Copiar a crew/.env y completar. NUNCA commitear crew/.env

# Orchestrator
ANTHROPIC_API_KEY=sk-ant-...

# Agentes secundarios
OPENAI_API_KEY=sk-...        # Codex (auditor)
GEMINI_API_KEY=AIza...       # Gemini (coder / DB)

# Telegram
TELEGRAM_BOT_TOKEN=          # Del @BotFather
TELEGRAM_ALLOWED_USERS=      # Tu user ID de Telegram (del @userinfobot)

# Opcional: modelo por agente
HERMES_CODER_MODEL=gemini-2.0-flash
HERMES_AUDITOR_MODEL=gpt-4o
HERMES_DB_MODEL=gemini-2.5-pro
